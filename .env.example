# HKJC Docker 環境配置
# 複製此文件為 .env 並填入實際值
# ⚠️ 重要: 生產環境必須更改所有默認密碼！

# MongoDB 配置
# ⚠️ 警告: 必須更改為強密碼！
MONGODB_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD_123!
MONGODB_APP_PASSWORD=CHANGE_ME_APP_PASSWORD_456!

# API 配置
API_PORT=3001
NODE_ENV=production

# Web 配置
WEB_PORT=80

# Odds Collector 配置
RACE_DATE=
VENUE=

# 時區
TZ=Asia/Hong_Kong

# 可選: 外部訪問配置
EXTERNAL_DOMAIN=localhost
ENABLE_SSL=false
